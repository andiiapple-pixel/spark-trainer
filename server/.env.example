NODE_ENV=development
PORT=3001

# PostgreSQL (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@localhost:5432/trainer_db

# Redis (Railway provides this automatically)
REDIS_URL=redis://localhost:6379

# Anthropic API key (server-side only — never exposed to browser)
ANTHROPIC_API_KEY=sk-ant-...

# JWT — generate RS256 keys:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   Then paste the single-line versions (replace newlines with \n)
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Long random string for refresh token HMAC — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_REFRESH_SECRET=your_long_random_refresh_secret_here

BCRYPT_ROUNDS=12

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=yourpassword
EMAIL_FROM=noreply@pockettrainer.app

# App
APP_NAME=Spark Trainer
APP_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173
